# Copy to .env and adjust for your environment.
# Values here match docker-compose.yml defaults for local development.

# ── FastAPI ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:19006","http://localhost:8081"]

# ── PostgreSQL ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://padel:padel@localhost:5432/padel
SYNC_DATABASE_URL=postgresql://padel:padel@localhost:5432/padel

# ── Redis / Celery ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MinIO / S3 ────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=padel
S3_SECRET_KEY=padelpadel
S3_BUCKET_VIDEOS=padel-videos
S3_REGION=us-east-1

# ── ML ────────────────────────────────────────────────────────────
ML_DEVICE=cpu                          # cpu | cuda
YOLO_WEIGHTS=yolov8n.pt                # auto-downloaded by ultralytics on first run
YOLO_POSE_WEIGHTS=yolov8n-pose.pt      # for future pose stage
# Download padel-specific weights from michele98/ball_tracking_padel and set:
TRACKNET_WEIGHTS=weights/tracknet_padel.pth
TARGET_FPS=30
MAX_VIDEO_SIZE_MB=2048
